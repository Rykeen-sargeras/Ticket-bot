<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Giveaway HQ — <%= giveaway.name %></title>
  <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

  <!-- Nav -->
  <nav class="topnav">
    <div class="nav-left">
      <span class="nav-logo">🎫</span>
      <span class="nav-title">Giveaway HQ</span>
      <span class="nav-divider">|</span>
      <a href="/" class="nav-link">Dashboard</a>
      <span class="nav-divider">›</span>
      <span class="nav-page"><%= giveaway.name %></span>
    </div>
    <div class="nav-right">
      <span class="gc-status status-<%= giveaway.status %>"><%= giveaway.status.toUpperCase() %></span>
      <a href="/logout" class="nav-link logout-btn">Logout</a>
    </div>
  </nav>

  <main class="container">

    <!-- Spinner Section -->
    <section class="card spinner-section">
      <div class="card-header">
        <h2>🎰 Raffle Spinner</h2>
        <span class="badge"><%= tickets.length %> entries</span>
      </div>

      <!-- Seed Controls -->
      <div class="seed-controls">
        <div class="seed-row">
          <label>Seed:</label>
          <input type="text" id="seedInput" placeholder="Auto-generated or paste to verify" class="text-input mono">
          <button onclick="generateNewSeed()" class="btn btn-silver btn-sm">Generate</button>
          <button onclick="copySeed()" class="btn btn-silver btn-sm">Copy</button>
        </div>
      </div>

      <!-- The Spinner Display -->
      <div class="spinner-wrapper" id="spinnerWrapper">
        <div class="spinner-viewport">
          <div class="spinner-highlight"></div>
          <div class="spinner-list" id="spinnerList">
            <!-- Entries rendered by JS -->
          </div>
        </div>
      </div>

      <div class="spin-actions">
        <button onclick="startSpin()" class="btn btn-red btn-lg" id="spinBtn">
          <% if (giveaway.status === 'completed') { %>
            RE-SPIN (New Seed)
          <% } else { %>
            🎰 SPIN THE WHEEL
          <% } %>
        </button>
        <button onclick="verifySpin()" class="btn btn-teal btn-sm">Verify Seed</button>
      </div>

      <!-- Winner Display -->
      <div class="winner-display" id="winnerDisplay" style="display:none;">
        <div class="winner-card" id="winnerCard">
          <div class="winner-label">🏆 WINNER</div>
          <div class="winner-name" id="winnerName"></div>
          <div class="winner-details" id="winnerDetails"></div>
          <div class="winner-seed">
            Seed: <code id="winnerSeed"></code>
          </div>
          <div class="winner-giveaway-name"><%= giveaway.name %></div>
        </div>

        <!-- Announce to Discord -->
        <div class="announce-section">
          <div class="announce-row">
            <input type="text" id="prizeInput" placeholder="Enter the prize (e.g. $50 Gift Card, Free Merch...)" class="text-input">
            <button onclick="announceWinner()" class="btn btn-red btn-lg" id="announceBtn">
              📢 Announce Winner in Discord
            </button>
          </div>
          <div class="announce-status" id="announceStatus"></div>
        </div>
      </div>

      <% if (giveaway.status === 'completed' && giveaway.winner_username) { %>
        <div class="previous-winner">
          <strong>Last Winner:</strong> <%= giveaway.winner_username %>
          (<%= giveaway.winner_role %>) — Ticket: <code><%= giveaway.winner_ticket_number %></code>
          — Seed: <code><%= giveaway.seed %></code>
        </div>
      <% } %>
    </section>

    <!-- Entries by Role -->
    <section class="card">
      <div class="card-header">
        <h2>📋 Entries by Role</h2>
      </div>

      <% const roleOrder = ['1% Gang', 'Short Shorts Gang', 'Scooter Gang', 'Banned Gang']; %>
      <% for (const roleName of roleOrder) { %>
        <% const group = grouped[roleName]; %>
        <% if (group && Object.keys(group.users).length > 0) { %>
          <div class="role-group">
            <div class="role-header" style="--role-color: <%= group.color %>">
              <span class="role-dot" style="background: <%= group.color %>"></span>
              <span class="role-name"><%= roleName %></span>
              <span class="role-count"><%= Object.keys(group.users).length %> users</span>
            </div>
            <div class="role-entries">
              <% for (const [userId, user] of Object.entries(group.users)) { %>
                <div class="entry-row">
                  <span class="entry-name"><%= user.displayName || user.username %></span>
                  <span class="entry-tickets">
                    <% user.tickets.forEach(t => { %>
                      <code class="ticket-num"><%= t.ticket_number %></code>
                    <% }) %>
                  </span>
                </div>
              <% } %>
            </div>
          </div>
        <% } %>
      <% } %>

      <% if (tickets.length === 0) { %>
        <div class="empty-state">
          <p>No tickets distributed yet. Use <code>/giveaway distribute <%= giveaway.id %></code> in Discord.</p>
        </div>
      <% } %>
    </section>

    <!-- Spin History -->
    <% if (history.length > 0) { %>
      <section class="card">
        <div class="card-header">
          <h2>📜 Spin History</h2>
        </div>
        <div class="history-list">
          <% history.forEach(h => { %>
            <div class="history-row">
              <span class="history-time"><%= new Date(h.spun_at).toLocaleString() %></span>
              <span class="history-winner">🏆 <%= h.username || 'Unknown' %></span>
              <code class="history-seed"><%= h.seed %></code>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>

  </main>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
  <script>
    const GIVEAWAY_ID = <%= giveaway.id %>;
    let allEntries = [];
    let isSpinning = false;
    let lastWinnerData = null;

    // Load entries on page load
    async function loadEntries() {
      const res = await fetch(`/api/giveaway/${GIVEAWAY_ID}/entries`);
      const data = await res.json();
      allEntries = data.entries;
      renderSpinnerList();
    }

    function renderSpinnerList() {
      const list = document.getElementById('spinnerList');
      if (allEntries.length === 0) {
        list.innerHTML = '<div class="spinner-empty">No entries yet</div>';
        return;
      }

      let html = '';
      allEntries.forEach((entry, i) => {
        const roleClass = entry.roleName.replace(/[^a-zA-Z]/g, '').toLowerCase();
        html += `<div class="spinner-entry" data-index="${i}" data-role="${roleClass}">
          <span class="se-name">${entry.displayName || entry.username}</span>
          <span class="se-role">${entry.roleName}</span>
          <span class="se-ticket">${entry.ticketNumber}</span>
        </div>`;
      });
      list.innerHTML = html;
    }

    function generateNewSeed() {
      const chars = '0123456789ABCDEF';
      let seed = '';
      const arr = new Uint8Array(16);
      crypto.getRandomValues(arr);
      for (let i = 0; i < 16; i++) seed += chars[arr[i] % 16];
      document.getElementById('seedInput').value = seed;
    }

    function copySeed() {
      const seed = document.getElementById('seedInput').value;
      if (seed) {
        navigator.clipboard.writeText(seed);
        const btn = event.target;
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy', 1500);
      }
    }

    async function startSpin() {
      if (isSpinning || allEntries.length === 0) return;
      isSpinning = true;
      
      const btn = document.getElementById('spinBtn');
      btn.disabled = true;
      btn.textContent = 'SPINNING...';

      const seed = document.getElementById('seedInput').value.trim() || undefined;

      const res = await fetch(`/api/giveaway/${GIVEAWAY_ID}/spin`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ seed })
      });
      const data = await res.json();

      if (!data.success) {
        alert('Spin failed: ' + data.error);
        btn.disabled = false;
        btn.textContent = '🎰 SPIN THE WHEEL';
        isSpinning = false;
        return;
      }

      document.getElementById('seedInput').value = data.seed;

      // Rebuild the spinner list using the EXACT entry order from the spin API
      // This ensures the winnerIndex lines up with the DOM elements
      allEntries = data.entries.map(e => ({
        displayName: e.displayName,
        username: e.username,
        roleName: e.roleName,
        ticketNumber: e.ticketNumber
      }));
      renderSpinnerList();

      // Small delay so DOM is ready
      await new Promise(r => setTimeout(r, 50));

      await runSpinAnimation(data.winnerIndex);

      showWinner(data.winner, data.seed);
      lastWinnerData = { winner: data.winner, seed: data.seed };

      btn.disabled = false;
      btn.textContent = 'RE-SPIN (New Seed)';
      isSpinning = false;
    }

    async function runSpinAnimation(winnerIndex) {
      const list = document.getElementById('spinnerList');
      const items = list.querySelectorAll('.spinner-entry');
      if (items.length === 0) return;

      const wrapper = document.getElementById('spinnerWrapper');
      wrapper.classList.add('spinning');

      items.forEach(el => el.classList.remove('highlight', 'winner-highlight'));

      // 3 full passes through all items, then land on the winner
      const totalSteps = items.length * 3 + winnerIndex;
      let currentIndex = 0;

      return new Promise(resolve => {
        let step = 0;
        const baseDelay = 40;
        const maxDelay = 400;

        function tick() {
          items.forEach(el => el.classList.remove('highlight'));

          const idx = currentIndex % items.length;
          items[idx].classList.add('highlight');
          items[idx].scrollIntoView({ behavior: 'smooth', block: 'center' });

          currentIndex++;
          step++;

          if (step >= totalSteps) {
            items[idx].classList.remove('highlight');
            items[idx].classList.add('winner-highlight');
            wrapper.classList.remove('spinning');
            setTimeout(resolve, 500);
            return;
          }

          const progress = step / totalSteps;
          const delay = baseDelay + (maxDelay - baseDelay) * Math.pow(progress, 3);
          setTimeout(tick, delay);
        }

        tick();
      });
    }

    function showWinner(winner, seed) {
      const display = document.getElementById('winnerDisplay');
      display.style.display = 'block';
      document.getElementById('winnerName').textContent = winner.displayName || winner.username;
      document.getElementById('winnerDetails').textContent = 
        `${winner.roleName} — Ticket: ${winner.ticketNumber}`;
      document.getElementById('winnerSeed').textContent = seed;

      display.scrollIntoView({ behavior: 'smooth' });
    }

    async function announceWinner() {
      const btn = document.getElementById('announceBtn');
      const status = document.getElementById('announceStatus');
      const prize = document.getElementById('prizeInput').value.trim();

      btn.disabled = true;
      btn.textContent = '📸 Capturing screenshot...';
      status.textContent = '';

      try {
        // Capture the winner card as an image
        const winnerCard = document.getElementById('winnerCard');
        const canvas = await html2canvas(winnerCard, {
          backgroundColor: '#0d1525',
          scale: 2,
          useCORS: true,
          logging: false
        });
        const imageBase64 = canvas.toDataURL('image/png');

        btn.textContent = '📢 Posting to Discord...';

        // Send to API
        const res = await fetch(`/api/giveaway/${GIVEAWAY_ID}/announce`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ prize, imageBase64 })
        });
        const data = await res.json();

        if (data.success) {
          status.innerHTML = '<span style="color: var(--teal);">✅ Winner announced in Discord!</span>';
          btn.textContent = '✅ Announced!';
          setTimeout(() => {
            btn.textContent = '📢 Announce Winner in Discord';
            btn.disabled = false;
          }, 3000);
        } else {
          throw new Error(data.error || 'Failed to announce');
        }
      } catch (err) {
        console.error('Announce error:', err);
        status.innerHTML = `<span style="color: var(--red);">❌ ${err.message}</span>`;
        btn.textContent = '📢 Announce Winner in Discord';
        btn.disabled = false;
      }
    }

    async function verifySpin() {
      const seed = document.getElementById('seedInput').value.trim();
      if (!seed) {
        alert('Enter a seed to verify');
        return;
      }

      const res = await fetch(`/api/giveaway/${GIVEAWAY_ID}/verify`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ seed })
      });
      const data = await res.json();

      if (data.success) {
        alert(
          `Verification Result:\n\n` +
          `Seed: ${seed}\n` +
          `Winner: ${data.winner.displayName || data.winner.username}\n` +
          `Role: ${data.winner.roleName}\n` +
          `Ticket: ${data.winner.ticketNumber}\n` +
          `Entry #${data.winnerIndex + 1} of ${data.totalEntries}`
        );
      }
    }

    // Init
    loadEntries();
  </script>
</body>
</html>
